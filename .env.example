# =============================================================================
# Polymarket API Credentials
# =============================================================================
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_SECRET=your_secret_here
POLYMARKET_PASSPHRASE=your_passphrase_here

# =============================================================================
# Target User to Copy
# =============================================================================
TARGET_USER_URL=https://polymarket.com/profile/@0x8dxd
TARGET_USERNAME=0x8dxd

# =============================================================================
# Trading Settings
# =============================================================================
MAX_TRADE_AMOUNT_USDC=50
TRADE_PERCENTAGE=10
MAX_TRADES_TO_TRACK=20
DAILY_SPENDING_LIMIT_USDC=250
DRY_RUN=true

# =============================================================================
# Dashboard Settings
# =============================================================================
# Use 0.0.0.0 to allow network access, 127.0.0.1 for localhost only
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

# =============================================================================
# Proxy Settings (for VPS deployments)
# =============================================================================
# Set to 'true' to enable proxy for all external API calls
USE_PROXY=false

# Proxy configuration (IPRoyal example)
PROXY_HOST=es.proxy.iproyal.com
PROXY_PORT=12321
PROXY_USERNAME=your_proxy_username
PROXY_PASSWORD=your_proxy_password

# =============================================================================
# Database Settings (for separated architecture)
# =============================================================================
# Database type: 'sqlite' (local) or 'postgresql' (remote/network)
DB_TYPE=sqlite

# SQLite settings (used when DB_TYPE=sqlite)
DATABASE_PATH=database/trades.db

# PostgreSQL settings (used when DB_TYPE=postgresql)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pmbot
DB_USER=pmbot
DB_PASSWORD=your_secure_password

# =============================================================================
# Bot Settings
# =============================================================================
LOG_LEVEL=INFO
POLL_INTERVAL=30

# =============================================================================
# Bitcoin Arbitrage Strategy Configuration
# =============================================================================

# Coinbase WebSocket
COINBASE_WS_URL=wss://ws-feed.exchange.coinbase.com
COINBASE_PRODUCT_ID=BTC-USD

# Arbitrage Threshold (0.001 = 0.1% price movement)
ARBITRAGE_THRESHOLD=0.001

# Position Management
MAX_POSITION_SIZE=50
MIN_POSITION_SIZE=5

# Profit Target & Stop Loss (0.02 = 2%, 0.01 = 1%)
PROFIT_TARGET=0.02
STOP_LOSS=0.01
STOP_LOSS_TIMEOUT=300

# Trading Settings
COOLDOWN_SECONDS=60
MAX_DAILY_TRADES=20

# Market Filter
MIN_MARKET_LIQUIDITY=10000
MAX_SPREAD=0.02

# WebSocket Settings
WS_RECONNECT_DELAY=5
WS_HEARTBEAT_INTERVAL=30

# Logging
LOG_TRADES=true
VERBOSE_LOGGING=false
